{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Flow Merge",
  "version": "0.1.0",
  "identifier": "com.flowmerge.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Flow Merge",
        "width": 1600,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NzdCOEQyQUI1NTdGRTYKUldUbWYxV3IwcmgzR0w1NzJXMUFDbFZ4a0EzNVM0ejZleW1EOWNoU1BqU05zZWFaRUZySXhtVE4K",
      "endpoints": [
        "https://github.com/example/example/releases/download/channel-stable/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
